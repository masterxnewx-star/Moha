-- ==================== WALLHOP SYSTEM ====================
local rParams = RaycastParams.new()
rParams.FilterType = Enum.RaycastFilterType.Blacklist

local function getWall()
    local char = LocalPlayer.Character
    if not char then return nil end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    rParams.FilterDescendantsInstances = {char}

    local dirs = {
        hrp.CFrame.LookVector,
        -hrp.CFrame.LookVector,
        hrp.CFrame.RightVector,
        -hrp.CFrame.RightVector
    }
    local dDist = 2
    local cHit = nil
    local mDist = dDist + 1

    for _, d in pairs(dirs) do
        local ry = Workspace:Raycast(hrp.Position, d * dDist, rParams)
        if ry and ry.Instance then
            if ry.Distance < mDist then
                mDist = ry.Distance
                cHit = ry
            end
        end
    end
    return cHit
end

UserInputService.JumpRequest:Connect(function()
    if not wallHopEnabled or not debounceJump then return end

    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local cam = Workspace.CurrentCamera

    if not (hum and hrp and cam) then return end

    local wr = getWall()

    if wr then
        debounceJump = false

        local wn = wr.Normal
        local hwn = Vector3.new(wn.X, 0, wn.Z).Unit
        if hwn.Magnitude < 0.1 then
            hwn = (hrp.CFrame.LookVector * Vector3.new(1,0,1)).Unit
            if hwn.Magnitude < 0.1 then hwn = Vector3.new(0,0,-1) end
        end
        local bDir = hwn

        local cl = cam.CFrame.LookVector
        local hcl = Vector3.new(cl.X, 0, cl.Z).Unit
        if hcl.Magnitude < 0.1 then hcl = bDir end

        local maxAng = math.rad(40)
        local dt = math.clamp(bDir:Dot(hcl), -1, 1)
        local angB = math.acos(dt)
        local crs = bDir:Cross(hcl)
        local rSig = math.sign(crs.Y)
        if rSig == 0 then angB = 0 end
        local actAng = math.min(angB, maxAng)
        local adjR = CFrame.Angles(0, actAng * rSig, 0)
        local iTarg = adjR * bDir

        hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + iTarg)

        RunService.Heartbeat:Wait()

        local jmped = false
        if hum and hum:GetState() ~= Enum.HumanoidStateType.Dead then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
            jmped = true
        end

        if jmped then
            local dirW = -bDir
            hrp.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + dirW)
        end

        task.wait(0.15)
        debounceJump = true
    end
end)
