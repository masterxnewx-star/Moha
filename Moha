local function generateObfuscatedName()
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_"
    local name = ""
    for i = 1, math.random(30, 50) do
        name = name .. chars:sub(math.random(1, #chars), math.random(1, #chars))
    end
    return name
end

local function generateRandomHex()
    local chars = "0123456789ABCDEF"
    local hex = ""
    for i = 1, math.random(8, 16) do
        hex = hex .. chars:sub(math.random(1, #chars), math.random(1, #chars))
    end
    return hex
end

local antiDebug = function()
    if getfenv and getgenv then
